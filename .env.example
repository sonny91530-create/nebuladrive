# ── NebulaDrive Environment Variables ──

# PostgreSQL connection string
# For local dev: postgresql://postgres:postgres@127.0.0.1:5432/app_db
# For Vercel + Neon: use the POOLED connection string (contains "-pooler" in URL)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/app_db

# JWT Secret for authentication tokens
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-to-a-random-64-char-string-in-production

# Force Neon HTTP driver even if URL doesn't contain "neon.tech"
# Set to "neon-http" when deploying to Vercel with Neon
# DB_DRIVER=neon-http
